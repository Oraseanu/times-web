APP_MODE=demo
#APP_MODE=cloud_prod


# Development server binding. Use 0.0.0.0 when devices on the same Wi-Fi
# need to open the app through this computer's local IP.
VITE_HOST=127.0.0.1
VITE_PORT=5173

# Used when APP_MODE=local_prod. Expected API contract:
# GET /state returns the app state JSON
# PUT /state saves the app state JSON
LOCAL_API_BASE_URL=http://127.0.0.1:8787
LOCAL_API_HOST=127.0.0.1
LOCAL_API_PORT=8787
LOCAL_DB_FILE=local-db/state.json

# Used when APP_MODE=cloud_prod with the same API contract as local_prod.
# Example after Worker deploy: https://times-web-api.<your-subdomain>.workers.dev
CLOUD_API_BASE_URL=https://times-web-api.oraseanu.workers.dev